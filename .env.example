# CallMeBot WhatsApp (see README for setup)
CALLMEBOT_PHONE=521234567890
CALLMEBOT_APIKEY=123456

# Admin login credentials
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=changeme

# Secret key for signing session cookies (generate a random string)
SECRET_KEY=change-this-to-a-random-secret

# Public URL of your app (used for QR code generation)
BASE_URL=https://your-app.up.railway.app

# SQLite database path (default: reports.db)
DB_PATH=reports.db
